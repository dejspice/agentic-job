{
  "name": "@dejsol/accelerators",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "node --require tsx/cjs --test src/__tests__/greenhouse-deterministic-resolution.test.ts",
    "test:integration": "node --require tsx/cjs --test src/__tests__/greenhouse-happy-path.integration.test.ts",
    "test:robustness": "node --require tsx/cjs --test src/__tests__/greenhouse-robustness.test.ts",
    "test:all": "node --require tsx/cjs --test src/__tests__/greenhouse-deterministic-resolution.test.ts src/__tests__/greenhouse-happy-path.integration.test.ts src/__tests__/greenhouse-robustness.test.ts",
    "typecheck:test": "tsc --project tsconfig.test.json"
  },
  "dependencies": {
    "@dejsol/core": "*"
  },
  "devDependencies": {
    "@dejsol/intelligence": "*",
    "@dejsol/state-machine": "*",
    "@dejsol/browser-worker": "*",
    "playwright": "^1.49.0"
  }
}
